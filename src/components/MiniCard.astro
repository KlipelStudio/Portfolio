---
const { mini } = Astro.props;

const base = import.meta.env.BASE_URL;

const asset = (p) =>
  /^https?:\/\//.test(p)
    ? p
    : `${base}${p}`.replace(/\/{2,}/g,'/');

const href = asset(`/minis/${mini.slug}/`);
const img = asset(mini.data.imagem);
---

<a href={href} class="text-decoration-none text-reset">

  <div class="card card-mini h-100 shadow-sm border-0">

    <img
      src={img}
      class="card-img-top"
      alt={mini.data.titulo}
    />

    <div class="card-body">

      <h3 class="h5 card-title mb-1">
        {mini.data.titulo}
      </h3>

      <p class="card-text text-muted small mb-2">
        {mini.data.descricao}
      </p>

      <div class="d-flex flex-wrap gap-1">

        {mini.data.classes?.map(c => (
          <span class="badge badge-classe">
            {c}
          </span>
        ))}

        {mini.data.racas?.map(r => (
          <span class="badge badge-raca">
            {r}
          </span>
        ))}

        {mini.data.cenarios?.map(c => (
          <span class="badge badge-cenario">
            {c}
          </span>
        ))}

      </div>

    </div>

  </div>

</a>

<style>

.badge-classe{
  background:#212529;
  color:#fff;
  font-size:.75rem;
  font-weight:600;
}

.badge-raca{
  background:#ffc107;
  color:#000;
  font-size:.75rem;
  font-weight:600;
}

.badge-cenario{
  background:#fff;
  color:#212529;
  border:1px solid #dee2e6;
  font-size:.75rem;
  font-weight:600;
}

</style>
