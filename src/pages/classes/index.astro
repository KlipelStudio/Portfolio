---

import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import MiniCard from '../../components/MiniCard.astro';

const minis=(await getCollection('minis'))
.filter(m=>m.data.classes?.length);

const classes=[
"Todos",
...[...new Set(
minis.flatMap(
m=>m.data.classes||[]
)
)].sort()
];

## const POR_PAGINA=100;

<Layout titulo="Classes & Estilos">

<section class="container py-5">

<div class="row">

<div class="col-lg-2">

<h4 class="mb-3">
Classes & Estilos
</h4>

<div class="d-flex flex-column gap-1">

{
classes.map(c=>(

<div class={c==="Todos"?"mb-3":""}>

<button
class:list={[
"btn",
"btn-sm",
c==="Todos"
?"btn-warning"
:"btn-outline-dark",
"filtro",
"w-100"
]}
data-classe={c}

>

{c}

</button>

</div>

))
}

</div>

</div>

<div class="col-lg-10">

<div
class="row g-3"
id="grid"
>

{
minis.map((m,index)=>(

<div
class="col-6 col-md-4 col-lg-custom mini"
data-index={index}
data-classes={JSON.stringify(
m.data.classes||[]
)}
>

<MiniCard mini={m}/>

</div>

))
}

</div>

<div
class="d-flex justify-content-center gap-2 mt-5"
id="paginacao"
>

</div>

</div>

</div>

</section>

<script is:inline>

let ativos=[];
let paginaAtual=1;

const POR_PAGINA=100;

const filtros=
document.querySelectorAll(".filtro");

const botaoTodos=
document.querySelector(
'[data-classe="Todos"]'
);

const minis=
[
...document.querySelectorAll(
".mini"
)
];

function atualizar(){

const filtrados=

minis.filter(el=>{

const classes=
JSON.parse(
el.dataset.classes||"[]"
);

return (
ativos.length===0
||
ativos.some(
c=>classes.includes(c)
)
);

});

minis.forEach(
m=>m.style.display="none"
);

const inicio=
(paginaAtual-1)
*
POR_PAGINA;

const fim=
inicio
+
POR_PAGINA;

filtrados
.slice(
inicio,
fim
)
.forEach(el=>{

el.style.display="";

});

criarPaginacao(
filtrados.length
);

}

function criarPaginacao(total){

const paginas=
Math.ceil(
total/POR_PAGINA
);

const container=
document.querySelector(
"#paginacao"
);

container.innerHTML="";

for(
let i=1;
i<=paginas;
i++
){

const btn=
document.createElement(
"button"
);

btn.innerText=i;

btn.className=
i===paginaAtual
?
"btn btn-warning btn-sm"
:
"btn btn-outline-dark btn-sm";

btn.onclick=()=>{

paginaAtual=i;

atualizar();

};

container.append(btn);

}

}

filtros.forEach(btn=>{

btn.addEventListener(
"click",
()=>{

const valor=
btn.dataset.classe;

paginaAtual=1;

if(
valor==="Todos"
){

ativos=[];

filtros.forEach(b=>{

b.classList.remove(
"btn-warning"
);

b.classList.add(
"btn-outline-dark"
);

});

btn.classList.remove(
"btn-outline-dark"
);

btn.classList.add(
"btn-warning"
);

}else{

botaoTodos.classList.remove(
"btn-warning"
);

botaoTodos.classList.add(
"btn-outline-dark"
);

if(
ativos.includes(valor)
){

ativos=
ativos.filter(
x=>x!==valor
);

btn.classList.remove(
"btn-warning"
);

btn.classList.add(
"btn-outline-dark"
);

}else{

ativos.push(valor);

btn.classList.remove(
"btn-outline-dark"
);

btn.classList.add(
"btn-warning"
);

}

}

atualizar();

});

});

atualizar();

</script>

<style>

.filtro{
font-size:.75rem;
padding:.2rem .4rem;
}

.col-lg-custom{
width:20%;
}

.mini img{
width:100%;
aspect-ratio:1/1;
object-fit:cover;
}

@media(max-width:992px){

.col-lg-custom{
width:auto;
}

}

</style>

</Layout>
