---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import MiniCard from '../components/MiniCard.astro';

const minis = await getCollection('minis');
---

<Layout
  titulo="Galeria — Klipel Studio"
  descricao="Galeria completa de miniaturas artesanais."
>
  <section class="container py-5">
    <h1 class="h2 mb-4">Galeria</h1>

    {minis.length === 0 ? (
      <p class="text-muted">
        Nenhuma miniatura cadastrada ainda.
      </p>
    ) : (
      <div class="row g-4">
        {minis.map((m) => (
          <div class="col-12 col-sm-6 col-lg-4">
            <MiniCard mini={m} />
          </div>
        ))}
      </div>
    )}
  </section>
</Layout>
