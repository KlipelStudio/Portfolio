---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import MiniCard from '../components/MiniCard.astro';

const minis = await getCollection('minis');

const classes = [
  ...new Set(
    minis.flatMap(m => m.data.classes || [])
  )
].sort();

const racas = [
  ...new Set(
    minis.flatMap(m => m.data.racas || [])
  )
].sort();

const cenarios = [
  ...new Set(
    minis.flatMap(m => m.data.cenarios || [])
  )
].sort();

const POR_PAGINA=100;
---

<Layout titulo="Galeria">

<section class="container py-5">

<div class="row">

<!-- SIDEBAR -->

<div class="col-lg-2 sidebar">

<h4 class="mb-4">
Galeria
</h4>

<button
id="todos"
class="btn btn-warning w-100 mb-3"
>
Limpar / Exibir Todos
</button>

<div id="filtros-ativos"></div>

<h6>
Classes & Estilos
</h6>

<div class="grupo">

{
classes.map(c=>(

<button
class="btn btn-outline-dark filtro-classe"
data-classe={c}
>
{c}
</button>

))
}

</div>


<h6>
Raças & Tipos
</h6>

<div class="grupo">

{
racas.map(r=>(

<button
class="btn btn-outline-dark filtro-raca"
data-raca={r}
>
{r}
</button>

))
}

</div>


<h6>
Cenários & Objetos
</h6>

<div class="grupo">

{
cenarios.map(c=>(

<button
class="btn btn-outline-dark filtro-cenario"
data-cenario={c}
>
{c}
</button>

))
}

</div>

</div>

<!-- GALERIA -->

<div class="col-lg-10">

<div
id="grid"
class="row g-3"
>

{
minis.map((m,index)=>(

<div
class="col-6 col-md-4 col-lg-custom mini"

data-index={index}

data-classes={JSON.stringify(
m.data.classes||[]
)}

data-racas={JSON.stringify(
m.data.racas||[]
)}

data-cenarios={JSON.stringify(
m.data.cenarios||[]
)}
>

<MiniCard mini={m}/>

</div>

))
}

</div>

<div
id="paginacao"
class="d-flex justify-content-center gap-2 mt-5"
></div>

</div>

</div>

</section>

<script is:inline>

let paginaAtual=1;

let classesAtivas=[];
let racasAtivas=[];
let cenariosAtivos=[];

const minis=[
...document.querySelectorAll(
".mini"
)
];

const filtrosContainer=
document.querySelector(
"#filtros-ativos"
);

function atualizar(){

const filtrados=minis.filter(el=>{

const classes=
JSON.parse(
el.dataset.classes||"[]"
);

const racas=
JSON.parse(
el.dataset.racas||"[]"
);

const cenarios=
JSON.parse(
el.dataset.cenarios||"[]"
);

const classeOk=
classesAtivas.length===0 ||
classesAtivas.some(
c=>classes.includes(c)
);

const racaOk=
racasAtivas.length===0 ||
racasAtivas.some(
r=>racas.includes(r)
);

const cenarioOk=
cenariosAtivos.length===0 ||
cenariosAtivos.some(
c=>cenarios.includes(c)
);

return(
classeOk &&
racaOk &&
cenarioOk
);

});

minis.forEach(
m=>m.style.display="none"
);

filtrados
.slice(
(paginaAtual-1)*100,
paginaAtual*100
)
.forEach(el=>{

el.style.display="";

});

renderizarTags();

criarPaginacao(
filtrados.length
);

}

function renderizarTags(){

filtrosContainer.innerHTML="";

function criarBadge(
lista,
tipo
){

lista.forEach(item=>{

const div=
document.createElement(
"div"
);

div.className=
"tag-wrapper";

div.innerHTML=`

<button
class="badge-filtro badge-${tipo}"
data-tipo="${tipo}"
data-valor="${item}"
>

${item}

<span class="badge-x">
×
</span>

</button>

`;

filtrosContainer.append(
div
);

});

}

criarBadge(
classesAtivas,
"classe"
);

criarBadge(
racasAtivas,
"raca"
);

criarBadge(
cenariosAtivos,
"cenario"
);

document
.querySelectorAll(
".badge-filtro"
)
.forEach(btn=>{

btn.onclick=()=>{

const tipo=
btn.dataset.tipo;

const valor=
btn.dataset.valor;

const mapa={

classe:classesAtivas,
raca:racasAtivas,
cenario:cenariosAtivos

};

const lista=
mapa[tipo];

lista.splice(
lista.indexOf(
valor
),
1
);

document
.querySelectorAll(
`.filtro-${tipo}`
)
.forEach(b=>{

if(
b.dataset[tipo]===valor
){

b.classList.remove(
"btn-warning"
);

b.classList.add(
"btn-outline-dark"
);

}

});

atualizar();

};

});

}

function criarPaginacao(total){

const paginas=
Math.ceil(
total/POR_PAGINA
);

const container=
document.querySelector(
"#paginacao"
);

container.innerHTML="";

for(
let i=1;
i<=paginas;
i++
){

const btn=
document.createElement(
"button"
);

btn.className=
i===paginaAtual
?
"btn btn-warning btn-sm"
:
"btn btn-outline-dark btn-sm";

btn.innerText=i;

btn.onclick=()=>{

paginaAtual=i;

atualizar();

};

container.append(
btn);

}

}

function alternar(
valor,
lista,
botao
){

if(
lista.includes(valor)
){

lista.splice(
lista.indexOf(valor),
1
);

botao.classList.remove(
"btn-warning"
);

botao.classList.add(
"btn-outline-dark"
);

}else{

lista.push(valor);

botao.classList.remove(
"btn-outline-dark"
);

botao.classList.add(
"btn-warning"
);

}

paginaAtual=1;

atualizar();

}

document
.querySelectorAll(
".filtro-classe"
)
.forEach(btn=>{

btn.onclick=()=>{

alternar(
btn.dataset.classe,
classesAtivas,
btn
);

};

});

document
.querySelectorAll(
".filtro-raca"
)
.forEach(btn=>{

btn.onclick=()=>{

alternar(
btn.dataset.raca,
racasAtivas,
btn
);

};

});

document
.querySelectorAll(
".filtro-cenario"
)
.forEach(btn=>{

btn.onclick=()=>{

alternar(
btn.dataset.cenario,
cenariosAtivos,
btn
);

};

});

document
.querySelector(
"#todos"
)
.onclick=()=>{

classesAtivas=[];
racasAtivas=[];
cenariosAtivos=[];

document
.querySelectorAll(
".filtro-classe,.filtro-raca,.filtro-cenario"
)
.forEach(btn=>{

btn.classList.remove(
"btn-warning"
);

btn.classList.add(
"btn-outline-dark"
);

});

paginaAtual=1;

atualizar();

};

atualizar();

</script>

<style>

.sidebar h6{

margin-top:30px;

}

.grupo{

display:flex;
flex-direction:column;
gap:6px;

margin-bottom:20px;

}

.col-lg-custom{

width:20%;

}

#filtros-ativos{

display:flex;
flex-wrap:wrap;

gap:8px;

margin:20px 0;

}

/* BADGES */

.badge-filtro{

border:none;

display:inline-flex;
align-items:center;

gap:6px;

padding:6px 10px;

border-radius:8px;

font-size:.75rem;
font-weight:700;

line-height:1;

cursor:pointer;

}

.badge-classe{

background:#212529;
color:white;

}

.badge-raca{

background:#ffc107;
color:black;

}

.badge-cenario{

background:#6c757d;
color:white;

}

.badge-x{

display:flex;

align-items:center;
justify-content:center;

width:14px;
height:14px;

border-radius:50%;

font-size:.65rem;

background:rgba(255,255,255,.2);

}

.badge-raca .badge-x{

background:rgba(0,0,0,.15);

}

@media(max-width:992px){

.col-lg-custom{

width:50%;

}

}

</style>

</Layout>
