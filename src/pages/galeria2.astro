---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import MiniCard from '../components/MiniCard.astro';

const minis = await getCollection('minis');

const classes=[
...new Set(
minis.flatMap(
m=>m.data.classes||[]
)
)
].sort();

const racas=[
...new Set(
minis.flatMap(
m=>m.data.racas||[]
)
)
].sort();

const cenarios=[
...new Set(
minis.flatMap(
m=>m.data.cenarios||[]
)
)
].sort();

---

<Layout titulo="Galeria">

<section class="container py-5">

<div class="row">

<!-- FILTROS -->
<div class="col-lg-2 sidebar">

<h4>Galeria</h4>

<button
id="todos"
class="btn btn-warning w-100 mb-3"
>
Limpar / Exibir Todos
</button>

<div id="filtros-ativos"></div>

<h6>Classes & Estilos</h6>

<div class="grupo">

{
classes.map(c=>(

<button
class="btn btn-outline-dark filtro-classe"
data-classe={c}
>
{c}
</button>

))
}

</div>

<h6>Raças & Tipos</h6>

<div class="grupo">

{
racas.map(r=>(

<button
class="btn btn-outline-dark filtro-raca"
data-raca={r}
>
{r}
</button>

))
}

</div>

<h6>Cenários & Objetos</h6>

<div class="grupo">

{
cenarios.map(c=>(

<button
class="btn btn-outline-dark filtro-cenario"
data-cenario={c}
>
{c}
</button>

))
}

</div>

</div>

<!-- GALERIA -->

<div class="col-lg-10">

<div
id="grid"
class="row g-3"
>

{
minis.map((m,index)=>(

<div
class="col-6 col-md-4 col-lg-custom mini"

data-index={index}

data-classes={JSON.stringify(
m.data.classes||[]
)}

data-racas={JSON.stringify(
m.data.racas||[]
)}

data-cenarios={JSON.stringify(
m.data.cenarios||[]
)}
>

<MiniCard mini={m}/>

</div>

))
}

</div>

<div
id="paginacao"
class="d-flex justify-content-center gap-2 mt-5"
></div>

</div>

</div>

</section>


<script is:inline>

let paginaAtual=1;

let classesAtivas=[];
let racasAtivas=[];
let cenariosAtivos=[];

const POR_PAGINA=100;

const minis=[
...document.querySelectorAll(".mini")
];

const filtrosContainer=
document.querySelector(
"#filtros-ativos"
);

function atualizar(){

const filtrados=minis.filter(el=>{

const classes=
JSON.parse(
el.dataset.classes||"[]"
);

const racas=
JSON.parse(
el.dataset.racas||"[]"
);

const cenarios=
JSON.parse(
el.dataset.cenarios||"[]"
);

return(

(
classesAtivas.length===0
||
classesAtivas.some(
c=>classes.includes(c)
)
)

&&

(
racasAtivas.length===0
||
racasAtivas.some(
r=>racas.includes(r)
)
)

&&

(
cenariosAtivos.length===0
||
cenariosAtivos.some(
c=>cenarios.includes(c)
)
)

);

});

minis.forEach(
m=>m.style.display="none"
);

filtrados
.slice(
(paginaAtual-1)*POR_PAGINA,
paginaAtual*POR_PAGINA
)
.forEach(el=>{

el.style.display="";

});

renderizarTags();

criarPaginacao(
filtrados.length
);

}

function renderizarTags(){

filtrosContainer.innerHTML="";

function criar(lista,tipo){

lista.forEach(item=>{

const tag=
document.createElement(
"div"
);

tag.className=
`tag-filtro ${tipo}`;

tag.innerHTML=`
<span>${item}</span>
<span
class="x"
data-tipo="${tipo}"
data-valor="${item}"
>
×
</span>
`;

filtrosContainer.append(
tag
);

});

}

criar(
classesAtivas,
"classe"
);

criar(
racasAtivas,
"raca"
);

criar(
cenariosAtivos,
"cenario"
);

document
.querySelectorAll(".x")
.forEach(btn=>{

btn.onclick=()=>{

const tipo=
btn.dataset.tipo;

const valor=
btn.dataset.valor;

const mapa={

classe:classesAtivas,
raca:racasAtivas,
cenario:cenariosAtivos

};

const lista=
mapa[tipo];

lista.splice(
lista.indexOf(
valor
),
1
);

document
.querySelectorAll(
`.filtro-${tipo}`
)
.forEach(b=>{

const dado=
b.dataset[tipo];

if(
dado===valor
){

b.classList.remove(
"btn-warning"
);

b.classList.add(
"btn-outline-dark"
);

}

});

atualizar();

};

});

}

function criarPaginacao(total){

const paginas=
Math.ceil(
total/POR_PAGINA
);

const div=
document.querySelector(
"#paginacao"
);

div.innerHTML="";

for(
let i=1;
i<=paginas;
i++
){

const btn=
document.createElement(
"button"
);

btn.className=
i===paginaAtual
?
"btn btn-warning btn-sm"
:
"btn btn-outline-dark btn-sm";

btn.innerText=i;

btn.onclick=()=>{

paginaAtual=i;
atualizar();

};

div.append(btn);

}

}

function alternar(
valor,
lista,
botao
){

if(
lista.includes(valor)
){

lista.splice(
lista.indexOf(valor),
1
);

botao.classList.remove(
"btn-warning"
);

botao.classList.add(
"btn-outline-dark"
);

}else{

lista.push(valor);

botao.classList.remove(
"btn-outline-dark"
);

botao.classList.add(
"btn-warning"
);

}

paginaAtual=1;

atualizar();

}

document
.querySelectorAll(
".filtro-classe"
)
.forEach(btn=>{

btn.onclick=()=>{

alternar(
btn.dataset.classe,
classesAtivas,
btn
);

};

});

document
.querySelectorAll(
".filtro-raca"
)
.forEach(btn=>{

btn.onclick=()=>{

alternar(
btn.dataset.raca,
racasAtivas,
btn
);

};

});

document
.querySelectorAll(
".filtro-cenario"
)
.forEach(btn=>{

btn.onclick=()=>{

alternar(
btn.dataset.cenario,
cenariosAtivos,
btn
);

};

});

document
.querySelector(
"#todos"
)
.onclick=()=>{

classesAtivas=[];
racasAtivas=[];
cenariosAtivos=[];

document
.querySelectorAll(
".filtro-classe,.filtro-raca,.filtro-cenario"
)
.forEach(btn=>{

btn.classList.remove(
"btn-warning"
);

btn.classList.add(
"btn-outline-dark"
);

});

paginaAtual=1;

atualizar();

};

atualizar();

</script>

<style>

.sidebar h6{

margin-top:30px;

}

.grupo{

display:flex;
flex-direction:column;
gap:6px;

}

.grupo button{

font-size:.8rem;

}

.col-lg-custom{

width:20%;

}

/* ===== BADGES FILTROS ATIVOS ===== */

#filtros-ativos{

display:flex;
flex-wrap:wrap;
gap:.45rem;

margin:15px 0 25px 0;

}

.tag-filtro{

display:inline-flex;
align-items:center;

width:auto;
max-width:fit-content;

padding:5px 10px;

border-radius:7px;

font-size:.75rem;
font-weight:700;

line-height:1;

white-space:nowrap;

}

/* mesmas cores das badges do card */

.tag-filtro.classe{

background:#212529;
color:white;

}

.tag-filtro.raca{

background:#ffc107;
color:black;

}

.tag-filtro.cenario{

background:#6c757d;
color:white;

}

/* X dentro da badge */

.x{

display:inline-flex;

align-items:center;
justify-content:center;

margin-left:6px;

width:14px;
height:14px;

border-radius:50%;

font-size:.65rem;
font-weight:700;

cursor:pointer;

transition:.2s;

background:rgba(255,255,255,.2);

line-height:1;

}

.tag-filtro.raca .x{

background:rgba(0,0,0,.15);

}

.x:hover{

transform:scale(1.15);

opacity:.8;

}

@media(max-width:992px){

.col-lg-custom{

width:50%;

}

}

</style>

</Layout>
