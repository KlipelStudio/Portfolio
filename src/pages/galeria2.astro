---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import MiniCard from '../components/MiniCard.astro';

const minis = await getCollection('minis');

const classes = [
  ...new Set(
    minis.flatMap(m => m.data.classes || [])
  )
].sort();

const racas = [
  ...new Set(
    minis.flatMap(m => m.data.racas || [])
  )
].sort();

const cenarios = [
  ...new Set(
    minis.flatMap(m => m.data.cenarios || [])
  )
].sort();

const POR_PAGINA=100;
---

<Layout titulo="Galeria">

<section class="container py-5">

<div class="row">

<div class="col-lg-2 sidebar">

<div class="sidebar-sticky">

<h4 class="mb-4">
Galeria
</h4>

<button
id="todos"
class="btn btn-warning w-100 mb-3"
>
Limpar / Exibir Todos
</button>

<div id="filtros-ativos"></div>

<div class="grupo-dropdown">

<button
class="titulo-filtro"
type="button"
data-target="grupo-classes"
>
<span>Classes & Estilos</span>
<span class="seta">›</span>
</button>

<div
id="grupo-classes"
class="grupo grupo-aberto"
>

{
classes.map(c=>(

<button
class="btn btn-outline-dark filtro-classe"
data-classe={c}
>
{c}
</button>

))
}

</div>

</div>

<div class="grupo-dropdown">

<button
class="titulo-filtro"
type="button"
data-target="grupo-racas"
>
<span>Raças & Tipos</span>
<span class="seta">›</span>
</button>

<div
id="grupo-racas"
class="grupo grupo-aberto"
>

{
racas.map(r=>(

<button
class="btn btn-outline-dark filtro-raca"
data-raca={r}
>
{r}
</button>

))
}

</div>

</div>

<div class="grupo-dropdown">

<button
class="titulo-filtro"
type="button"
data-target="grupo-cenarios"
>
<span>Cenários & Objetos</span>
<span class="seta">›</span>
</button>

<div
id="grupo-cenarios"
class="grupo grupo-aberto"
>

{
cenarios.map(c=>(

<button
class="btn btn-outline-dark filtro-cenario"
data-cenario={c}
>
{c}
</button>

))
}

</div>

</div>

</div>

</div>

<div class="col-lg-10">

<div
id="grid"
class="row g-3"
>

{
minis.map((m,index)=>(

<div
class="col-6 col-md-4 col-lg-custom mini"

data-index={index}

data-classes={JSON.stringify(
m.data.classes||[]
)}

data-racas={JSON.stringify(
m.data.racas||[]
)}

data-cenarios={JSON.stringify(
m.data.cenarios||[]
)}
>

<MiniCard mini={m}/>

</div>

))
}

</div>

<div
id="paginacao"
class="d-flex justify-content-center gap-2 mt-5"
></div>

</div>

</div>

</section>

<script is:inline>

let paginaAtual=1;

let classesAtivas=[];
let racasAtivas=[];
let cenariosAtivos=[];

const minis=[
...document.querySelectorAll(
".mini"
)
];

const filtrosContainer=
document.querySelector(
"#filtros-ativos"
);

function atualizar(){

const filtrados=minis.filter(el=>{

const classes=
JSON.parse(
el.dataset.classes||"[]"
);

const racas=
JSON.parse(
el.dataset.racas||"[]"
);

const cenarios=
JSON.parse(
el.dataset.cenarios||"[]"
);

const classeOk=
classesAtivas.length===0 ||
classesAtivas.some(
c=>classes.includes(c)
);

const racaOk=
racasAtivas.length===0 ||
racasAtivas.some(
r=>racas.includes(r)
);

const cenarioOk=
cenariosAtivos.length===0 ||
cenariosAtivos.some(
c=>cenarios.includes(c)
);

return(
classeOk &&
racaOk &&
cenarioOk
);

});

minis.forEach(
m=>m.style.display="none"
);

filtrados
.slice(
(paginaAtual-1)*100,
paginaAtual*100
)
.forEach(el=>{

el.style.display="";

});

renderizarTags();

criarPaginacao(
filtrados.length
);

}

function renderizarTags(){

filtrosContainer.innerHTML="";

function criarBadge(
lista,
tipo
){

lista.forEach(item=>{

const div=
document.createElement(
"div"
);

div.className=
"tag-wrapper";

div.innerHTML=`

<button
class="badge-filtro badge-${tipo}"
data-tipo="${tipo}"
data-valor="${item}"
>

${item}

<span class="badge-x">
×
</span>

</button>

`;

filtrosContainer.append(
div
);

});

}

criarBadge(
classesAtivas,
"classe"
);

criarBadge(
racasAtivas,
"raca"
);

criarBadge(
cenariosAtivos,
"cenario"
);

document
.querySelectorAll(
".badge-filtro"
)
.forEach(btn=>{

btn.onclick=()=>{

const tipo=
btn.dataset.tipo;

const valor=
btn.dataset.valor;

const mapa={

classe:classesAtivas,
raca:racasAtivas,
cenario:cenariosAtivos

};

const lista=
mapa[tipo];

lista.splice(
lista.indexOf(
valor
),
1
);

document
.querySelectorAll(
`.filtro-${tipo}`
)
.forEach(b=>{

if(
b.dataset[tipo]===valor
){

b.classList.remove(
"btn-warning"
);

b.classList.add(
"btn-outline-dark"
);

}

});

atualizar();

};

});

}

function criarPaginacao(total){

const paginas=
Math.ceil(
total/POR_PAGINA
);

const container=
document.querySelector(
"#paginacao"
);

container.innerHTML="";

for(
let i=1;
i<=paginas;
i++
){

const btn=
document.createElement(
"button"
);

btn.className=
i===paginaAtual
?
"btn btn-warning btn-sm"
:
"btn btn-outline-dark btn-sm";

btn.innerText=i;

btn.onclick=()=>{

paginaAtual=i;

atualizar();

};

container.append(
btn);

}

}

function alternar(
valor,
lista,
botao
){

if(
lista.includes(valor)
){

lista.splice(
lista.indexOf(valor),
1
);

botao.classList.remove(
"btn-warning"
);

botao.classList.add(
"btn-outline-dark"
);

}else{

lista.push(valor);

botao.classList.remove(
"btn-outline-dark"
);

botao.classList.add(
"btn-warning"
);

}

paginaAtual=1;

atualizar();

}

document
.querySelectorAll(
".filtro-classe"
)
.forEach(btn=>{

btn.onclick=()=>{

alternar(
btn.dataset.classe,
classesAtivas,
btn
);

};

});

document
.querySelectorAll(
".filtro-raca"
)
.forEach(btn=>{

btn.onclick=()=>{

alternar(
btn.dataset.raca,
racasAtivas,
btn
);

};

});

document
.querySelectorAll(
".filtro-cenario"
)
.forEach(btn=>{

btn.onclick=()=>{

alternar(
btn.dataset.cenario,
cenariosAtivos,
btn
);

};

});

document
.querySelector(
"#todos"
)
.onclick=()=>{

classesAtivas=[];
racasAtivas=[];
cenariosAtivos=[];

document
.querySelectorAll(
".filtro-classe,.filtro-raca,.filtro-cenario"
)
.forEach(btn=>{

btn.classList.remove(
"btn-warning"
);

btn.classList.add(
"btn-outline-dark"
);

});

paginaAtual=1;

atualizar();

};

document
.querySelectorAll(
".titulo-filtro"
)
.forEach(btn=>{

btn.onclick=()=>{

const target=
document.getElementById(
btn.dataset.target
);

target.classList.toggle(
"grupo-aberto"
);

btn.classList.toggle(
"fechado"
);

};

});

atualizar();

</script>

<style>

.sidebar-sticky{

position:sticky;
top:20px;

max-height:calc(100vh - 40px);
overflow-y:auto;

padding-right:6px;

}

.grupo-dropdown{

margin-bottom:20px;

}

.titulo-filtro{

width:100%;

border:none;
background:transparent;

display:flex;
align-items:center;
justify-content:space-between;

padding:0;

margin-top:26px;
margin-bottom:10px;

font-size:1rem;
font-weight:700;

color:#212529;

cursor:pointer;

}

.seta{

font-size:1.4rem;
line-height:1;

transform:rotate(90deg);
transition:.2s ease;

}

.titulo-filtro.fechado .seta{

transform:rotate(0deg);

}

.grupo{

display:none;
flex-direction:column;
gap:6px;

}

.grupo.grupo-aberto{

display:flex;

}

.col-lg-custom{

width:20%;

}

#filtros-ativos{

display:flex;
flex-wrap:wrap;

gap:6px;

margin:20px 0;

}

/* BADGES DOS FILTROS ATIVOS */

:global(.badge-filtro){

border:none;

display:inline-flex;
align-items:center;

gap:5px;

padding:4px 8px;

border-radius:8px;

font-size:.8rem;
font-weight:600;

line-height:1;

cursor:pointer;

}

:global(.badge-classe){

background:#212529;
color:#fff;

}

:global(.badge-raca){

background:#ffc107;
color:#000;

}

:global(.badge-cenario){

background:#fff;
color:#212529;

border:1px solid #d0d7de;

}

:global(.badge-x){

display:flex;

align-items:center;
justify-content:center;

width:13px;
height:13px;

border-radius:50%;

font-size:.6rem;

background:rgba(255,255,255,.2);

}

:global(.badge-raca .badge-x),
:global(.badge-cenario .badge-x){

background:rgba(0,0,0,.15);

}

@media(max-width:992px){

.sidebar-sticky{

position:static;

max-height:none;
overflow-y:visible;

padding-right:0;

margin-bottom:30px;

}

.col-lg-custom{

width:50%;

}

}

</style>

</Layout>
