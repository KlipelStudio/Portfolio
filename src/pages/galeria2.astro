---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import MiniCard from '../components/MiniCard.astro';

const minis = await getCollection('minis');

const classes = [
...new Set(
minis.flatMap(
m => m.data.classes || []
)
)
].sort();

const racas = [
...new Set(
minis.flatMap(
m => m.data.racas || []
)
)
].sort();

const cenarios = [
...new Set(
minis.flatMap(
m => m.data.cenarios || []
)
)
].sort();

const POR_PAGINA = 100;
---

<Layout titulo="Galeria">

<section class="container py-5">

<div class="row">

<div class="col-lg-2">

<h4 class="mb-3">
Galeria
</h4>

<div class="mb-3">

<button
class="btn btn-warning btn-sm w-100"
id="todos"
>
Limpar/ Exibir Todos
</button>

</div>

<!-- FILTROS ATIVOS -->
<div
id="filtros-ativos"
class="d-flex flex-wrap gap-2 mb-4"
></div>

<h6 class="mb-2">
Classes & Estilos
</h6>

<div class="d-flex flex-column gap-1 mb-4">

{
classes.map(c => (

<button
class="btn btn-outline-dark btn-sm filtro-classe w-100"
data-classe={c}
>
{c}
</button>

))
}

</div>

<h6 class="mb-2">
Raças & Tipos
</h6>

<div class="d-flex flex-column gap-1 mb-4">

{
racas.map(r => (

<button
class="btn btn-outline-dark btn-sm filtro-raca w-100"
data-raca={r}
>
{r}
</button>

))
}

</div>

<h6 class="mb-2">
Cenários & Objetos
</h6>

<div class="d-flex flex-column gap-1">

{
cenarios.map(c => (

<button
class="btn btn-outline-dark btn-sm filtro-cenario w-100"
data-cenario={c}
>
{c}
</button>

))
}

</div>

</div>

<div class="col-lg-10">

<div
class="row g-3"
id="grid"
>

{
minis.map((m,index)=>(

<div
class="col-6 col-md-4 col-lg-custom mini"
data-index={index}
data-classes={JSON.stringify(
m.data.classes || []
)}
data-racas={JSON.stringify(
m.data.racas || []
)}
data-cenarios={JSON.stringify(
m.data.cenarios || []
)}
>

<MiniCard mini={m} />

</div>

))
}

</div>

<div
class="d-flex justify-content-center gap-2 mt-5"
id="paginacao"
>

</div>

</div>

</div>

</section>

<script is:inline>

let paginaAtual=1;

let classesAtivas=[];
let racasAtivas=[];
let cenariosAtivos=[];

const POR_PAGINA=100;

const minis=[
...document.querySelectorAll(".mini")
];

const botaoTodos=
document.querySelector("#todos");

const containerFiltros=
document.querySelector(
"#filtros-ativos"
);

function atualizar(){

const filtrados=

minis.filter(el=>{

const classes=
JSON.parse(
el.dataset.classes || "[]"
);

const racas=
JSON.parse(
el.dataset.racas || "[]"
);

const cenarios=
JSON.parse(
el.dataset.cenarios || "[]"
);

const classeOk=
classesAtivas.length===0
||
classesAtivas.some(
c=>classes.includes(c)
);

const racaOk=
racasAtivas.length===0
||
racasAtivas.some(
r=>racas.includes(r)
);

const cenarioOk=
cenariosAtivos.length===0
||
cenariosAtivos.some(
c=>cenarios.includes(c)
);

return(
classeOk
&&
racaOk
&&
cenarioOk
);

});

minis.forEach(
m=>m.style.display="none"
);

const inicio=
(paginaAtual-1)
*
POR_PAGINA;

const fim=
inicio+
POR_PAGINA;

filtrados
.slice(inicio,fim)
.forEach(el=>{

el.style.display="";

});

criarPaginacao(
filtrados.length
);

renderizarFiltros();

}

function renderizarFiltros(){

containerFiltros.innerHTML="";

const criarBadge=(valor,tipo)=>{

const badge=
document.createElement(
"div"
);

badge.className=
`filtro-badge ${tipo}`;

badge.innerHTML=`
<span>${valor}</span>
<button
class="fechar-filtro"
data-valor="${valor}"
data-tipo="${tipo}"
>
✕
</button>
`;

containerFiltros.append(
badge
);

};

classesAtivas.forEach(
v=>criarBadge(
v,
"classe"
)
);

racasAtivas.forEach(
v=>criarBadge(
v,
"raca"
)
);

cenariosAtivos.forEach(
v=>criarBadge(
v,
"cenario"
)
);

document
.querySelectorAll(
".fechar-filtro"
)
.forEach(btn=>{

btn.onclick=()=>{

const valor=
btn.dataset.valor;

const tipo=
btn.dataset.tipo;

if(tipo==="classe"){
removerFiltro(
valor,
classesAtivas,
".filtro-classe",
"classe"
);
}

if(tipo==="raca"){
removerFiltro(
valor,
racasAtivas,
".filtro-raca",
"raca"
);
}

if(tipo==="cenario"){
removerFiltro(
valor,
cenariosAtivos,
".filtro-cenario",
"cenario"
);
}

};

});

}

function removerFiltro(
valor,
lista,
seletor,
tipo
){

const index=
lista.indexOf(
valor
);

if(index>-1){

lista.splice(
index,
1
);

}

document
.querySelectorAll(
seletor
)
.forEach(btn=>{

const data=
btn.dataset[tipo];

if(data===valor){

btn.classList.remove(
"btn-warning"
);

btn.classList.add(
"btn-outline-dark";

)

}

});

atualizar();

}

function criarPaginacao(total){

const paginas=
Math.ceil(
total/POR_PAGINA
);

const container=
document.querySelector(
"#paginacao"
);

container.innerHTML="";

for(
let i=1;
i<=paginas;
i++
){

const btn=
document.createElement(
"button"
);

btn.innerText=i;

btn.className=
i===paginaAtual
?
"btn btn-warning btn-sm"
:
"btn btn-outline-dark btn-sm";

btn.onclick=()=>{

paginaAtual=i;

atualizar();

};

container.append(
btn
);

}

}

function resetarTodos(){

classesAtivas=[];
racasAtivas=[];
cenariosAtivos=[];

document
.querySelectorAll(
".filtro-classe,.filtro-raca,.filtro-cenario"
)
.forEach(btn=>{

btn.classList.remove(
"btn-warning"
);

btn.classList.add(
"btn-outline-dark"
);

});

paginaAtual=1;

atualizar();

}

botaoTodos.addEventListener(
"click",
resetarTodos
);

function alternarFiltro(
valor,
lista,
botao
){

if(
lista.includes(
valor
)
){

lista.splice(
lista.indexOf(
valor
),
1
);

botao.classList.remove(
"btn-warning"
);

botao.classList.add(
"btn-outline-dark"
);

}else{

lista.push(
valor
);

botao.classList.remove(
"btn-outline-dark"
);

botao.classList.add(
"btn-warning"
);

}

paginaAtual=1;

atualizar();

}

document
.querySelectorAll(
".filtro-classe"
)
.forEach(btn=>{

btn.addEventListener(
"click",
()=>{

alternarFiltro(
btn.dataset.classe,
classesAtivas,
btn
);

});

});

document
.querySelectorAll(
".filtro-raca"
)
.forEach(btn=>{

btn.addEventListener(
"click",
()=>{

alternarFiltro(
btn.dataset.raca,
racasAtivas,
btn
);

});

});

document
.querySelectorAll(
".filtro-cenario"
)
.forEach(btn=>{

btn.addEventListener(
"click",
()=>{

alternarFiltro(
btn.dataset.cenario,
cenariosAtivos,
btn
);

});

});

atualizar();

</script>

<style>

.filtro-classe,
.filtro-raca,
.filtro-cenario{
font-size:.75rem;
padding:.2rem .4rem;
}

.col-lg-custom{
width:20%;
}

.mini img{
width:100%;
aspect-ratio:1/1;
object-fit:cover;
}

/* BADGES */

.filtro-badge{

display:flex;
align-items:center;
gap:6px;

padding:4px 10px;

border-radius:8px;

font-size:.75rem;
font-weight:600;

width:fit-content;
}

.filtro-badge.classe{

background:#1f2430;
color:white;
}

.filtro-badge.raca{

background:#ffc107;
color:black;
}

.filtro-badge.cenario{

background:#6c757d;
color:white;
}

.fechar-filtro{

background:none;
border:none;

color:inherit;

font-size:.8rem;
font-weight:bold;

cursor:pointer;

padding:0;
margin:0;
}

.fechar-filtro:hover{

opacity:.7;

}

@media(max-width:992px){

.container>.row{

display:flex;
flex-wrap:nowrap;
align-items:flex-start;
gap:.5rem;

}

.col-lg-2{

flex:0 0 110px;
width:110px;
max-width:110px;
padding-right:0;

}

.col-lg-10{

flex:1;
min-width:0;
padding-left:0;

}

.col-lg-2 h4{

font-size:1.3rem;

}

.col-lg-2 h6{

font-size:.8rem;

}

.filtro-classe,
.filtro-raca,
.filtro-cenario,
#todos{

font-size:.65rem;
padding:.25rem;

}

.col-lg-custom{

width:50%;
padding:.25rem;

}

.mini{

width:50%;

}

#paginacao{

flex-wrap:wrap;

}

}

</style>

</Layout>
