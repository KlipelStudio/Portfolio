---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const minis = await getCollection('minis');

  return minis.map((m) => ({
    params: { slug: m.slug },
    props: { mini: m }
  }));
}

const { mini } = Astro.props;
const { Content } = await mini.render();

const base = import.meta.env.BASE_URL;

const url = (p) =>
  `${base}${p}`.replace(/\/{2,}/g, '/');

const asset = (p) =>
  /^https?:\/\//.test(p)
    ? p
    : `${base}${p}`.replace(/\/{2,}/g, '/');

const imgs = [
  mini.data.imagem,
  ...(mini.data.galeria ?? [])
].filter(Boolean);
---

<Layout
  titulo={`${mini.data.titulo} — Klipel Studio`}
  descricao={mini.data.descricao}
>
  <section class="container py-5">

    <!-- Botão voltar para página anterior -->
    <button
      class="btn btn-sm btn-outline-dark mb-4"
      onclick="history.back()"
      type="button"
    >
      ← Voltar
    </button>

    <div class="row g-5 align-items-start">

      <!-- Conteúdo à esquerda -->
      <div class="col-lg-5 order-2 order-lg-1">

        <h1 class="h2">{mini.data.titulo}</h1>

        <div class="d-flex flex-wrap gap-2 my-3">

          {/* Classe = preto */}
          {mini.data.classes?.map((c) => (
            <span class="badge text-bg-dark">{c}</span>
          ))}

          {/* Raça = amarelo */}
          {mini.data.racas?.map((r) => (
            <span
              class="badge"
              style="background-color:#ffc107;color:#000;"
            >
              {r}
            </span>
          ))}

          {/* Cenário = branco */}
          {mini.data.cenarios?.map((c) => (
            <span
              class="badge border"
              style="background-color:#fff;color:#000;"
            >
              {c}
            </span>
          ))}

        </div>

        <p class="lead">{mini.data.descricao}</p>

        <article class="mt-4">
          <Content />
        </article>

        <a href={url('/contato')} class="btn btn-warning mt-4">
          Encomendar peça semelhante
        </a>

      </div>

      <!-- Foto à direita -->
      <div class="col-lg-7 order-1 order-lg-2">

        <img
          src={asset(mini.data.imagem)}
          class="img-fluid rounded shadow-sm w-100"
          alt={mini.data.titulo}
        />

        {imgs.length > 1 && (
          <div class="row g-2 mt-3">
            {imgs.map((src) => (
              <div class="col-3">
                <img
                  src={asset(src)}
                  class="img-fluid rounded border"
                  alt={mini.data.titulo}
                  loading="lazy"
                />
              </div>
            ))}
          </div>
        )}

      </div>

    </div>

  </section>
</Layout>
