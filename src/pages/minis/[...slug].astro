import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
const minis = await getCollection('minis');

return minis.map((m) => ({
params: {
slug: m.slug
},
props: {
mini: m
}
}));
}

const { mini } = Astro.props;

const { Content } = await mini.render();

const base = import.meta.env.BASE_URL;

function url(p) {
return `${base}${p}`.replace(//{2,}/g, '/');
}

function asset(p) {
if (!p) return '';

return /^https?:///.test(p)
? p
: `${base}${p}`.replace(//{2,}/g, '/');
}

const imgs = [
mini.data.imagem,
...(mini.data.galeria ?? [])
].filter(Boolean);

