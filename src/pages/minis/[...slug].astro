---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const minis = await getCollection('minis');

  return minis.map((m) => ({
    params: { slug: m.slug },
    props: { mini: m }
  }));
}

const { mini } = Astro.props;
const { Content } = await mini.render();

const base = import.meta.env.BASE_URL;

const asset = (p) =>
  /^https?:\/\//.test(p)
    ? p
    : `${base}${p}`.replace(/\/{2,}/g, '/');

const imgs = [
  mini.data.imagem,
  ...(mini.data.galeria ?? [])
].filter(Boolean);
---

<Layout
  titulo={`${mini.data.titulo} — Klipel Studio`}
  descricao={mini.data.descricao}
>
  <section
    class="container py-3"
    style="height: calc(100vh - 90px);"
  >
    <button
      class="btn btn-sm btn-outline-dark mb-4"
      onclick="history.back()"
      type="button"
    >
      ← Voltar
    </button>

    <div class="row g-4 h-100 align-items-start">

      <!-- Informações -->
      <div class="col-lg-4">

        <h1 class="display-5 fw-bold mb-3">
          {mini.data.titulo}
        </h1>

        <div class="d-flex flex-wrap gap-2 mb-4">

          {/* Classe = preto */}
          {mini.data.classes?.map((c) => (
            <span class="badge text-bg-dark fs-6">
              {c}
            </span>
          ))}

          {/* Raça = amarelo */}
          {mini.data.racas?.map((r) => (
            <span
              class="badge fs-6"
              style="background:#ffc107;color:#000;"
            >
              {r}
            </span>
          ))}

          {/* Cenário = branco */}
          {mini.data.cenarios?.map((c) => (
            <span
              class="badge fs-6 border"
              style="background:#fff;color:#000;"
            >
              {c}
            </span>
          ))}

        </div>

        {mini.data.descricao && (
          <p class="lead">
            {mini.data.descricao}
          </p>
        )}

        <article class="mt-4">
          <Content />
        </article>

      </div>

      <!-- Imagem -->
      <div class="col-lg-8 d-flex justify-content-center align-items-start">

        <img
          src={asset(mini.data.imagem)}
          alt={mini.data.titulo}
          class="rounded shadow-sm"
          style="
            height: 85vh;
            width: auto;
            max-width: 100%;
            object-fit: contain;
          "
        />

      </div>

    </div>
  </section>
</Layout>
