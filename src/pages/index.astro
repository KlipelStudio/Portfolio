---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import MiniCard from '../components/MiniCard.astro';

const base = import.meta.env.BASE_URL;

const url = (p) =>
`${base}${p}`.replace(/\/{2,}/g,'/');

const minis = await getCollection('minis');

const destaques =
minis.filter(
m=>m.data.destaque
).slice(0,6);

const vitrine =
destaques.length
? destaques
: minis.slice(0,6);
---

<Layout titulo="Klipel Studio — Miniaturas para Aventureiros">

<section
class="hero text-light py-5"
style="background-color: var(--kl-dark);"
>

<div class="container py-5 text-center">

<h1 class="display-4 text-gold mb-3">
Miniaturas para suas aventuras
</h1>

<p
class="lead mx-auto"
style="max-width:640px;"
>
Esculturas artesanais de heróis, vilões e monstros para dar vida às suas mesas de RPG. Pintura sob medida e modelos exclusivos.
</p>

<div class="d-flex justify-content-center gap-3 mt-4 flex-wrap">

<a
href={url('/classes')}
class="btn btn-warning btn-lg px-4"
>
Classes & Estilos
</a>

<a
href={url('/racas')}
class="btn btn-warning btn-lg px-4"
>
Raças & Tipos
</a>

<a
href={url('/cenarios')}
class="btn btn-warning btn-lg px-4"
>
Cenários & Objetos
</a>

</div>

</div>

</section>

<section class="container py-5">

<h2 class="h3 mb-4 text-center">
Destaques
</h2>

{
vitrine.length===0
? (
<p class="text-center text-muted">
Nenhuma miniatura cadastrada ainda.
</p>
)
: (
<div class="row g-4">

{
vitrine.map(m=>(

<div class="col-12 col-sm-6 col-lg-4">
<MiniCard mini={m}/>
</div>

))
}

</div>
)
}

<div class="text-center mt-4">

<a
href={url('/galeria')}
class="btn btn-dark"
>
Ver todas as miniaturas
</a>

</div>

</section>

</Layout>
