---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const base = import.meta.env.BASE_URL;

const url = (p) =>
`${base}${p}`.replace(/\/{2,}/g,'/');

const minis = await getCollection('minis');

const miniaturas = minis
.filter(
  m => m.data.destaque === true
)
.map(m=>({
  slug:m.slug,
  href:url(`/minis/${m.slug}/`),
  titulo:m.data.titulo,
  imagem:m.data.imagem,
  classes:m.data.classes || [],
  racas:m.data.racas || [],
  sexo:m.data.sexo || [],
  cenarios:m.data.cenarios || []
}));
---

<Layout titulo="Klipel Studio — Miniaturas para Aventureiros">

<section class="hero-home">

<div class="container text-center hero-conteudo">

<h1>
Miniaturas para suas aventuras
</h1>

<p>
Heróis, vilões, monstros e cenários para dar vida às suas mesas de RPG.
</p>

<a
href={url('/galeria')}
class="btn btn-warning btn-lg px-5"
>
VER PORTFÓLIO
</a>

</div>

<div class="faixas-aviso" aria-label="Avisos do site">

<div class="faixa faixa-principal">
<span>
Atualizações semanais 🔥
</span>
</div>

<div class="faixa faixa-secundaria">
<span>
Não encontrou o que procura? Entre em contato com a gente!
</span>
</div>

</div>

</section>

<section class="container py-4">

<div class="destaques-topo text-center">

<h2>
Destaques
</h2>

<p>
Uma seleção do nosso catálogo.
</p>

</div>

{
miniaturas.length===0
? (
<p class="text-center text-muted">
Nenhuma miniatura cadastrada ainda.
</p>
)
: (
<div
id="vitrine-aleatoria"
class="row g-3"
></div>
)
}

<div class="text-center mt-4">

<a
href={url('/galeria')}
class="btn btn-dark"
>
Ver todas as miniaturas
</a>

</div>

</section>

<script
type="application/json"
id="miniaturas-data"
set:html={JSON.stringify(miniaturas)}
/>

<script is:inline>

const base =
document
.querySelector(
"base"
)
?.href || "/";

const dados =
JSON.parse(
document
.querySelector(
"#miniaturas-data"
)
.textContent
);

const container =
document.querySelector(
"#vitrine-aleatoria"
);

function asset(p){

if(
/^https?:\/\//.test(p)
){

return p;

}

return `${base}${p}`.replace(
/\/{2,}/g,
"/"
);

}

function embaralhar(lista){

return [...lista].sort(
()=>Math.random()-.5
);

}

function criarBadges(lista,tipo){

return lista.map(item=>`

<span class="badge badge-home badge-${tipo}">
${item}
</span>

`).join("");

}

function criarCard(mini){

const href =
mini.href;

const img =
asset(mini.imagem);

return `

<div class="col-6 col-lg-4">

<a href="${href}" class="text-decoration-none text-reset">

<div class="card card-home h-100 shadow-sm border-0">

<img
src="${img}"
class="card-img-top"
alt="${mini.titulo}"
/>

<div class="card-body">

<h3 class="card-title mb-2">
${mini.titulo}
</h3>

<div class="d-flex flex-wrap gap-1">

${criarBadges(mini.classes,"classe")}
${criarBadges(mini.racas,"raca")}
${criarBadges(mini.sexo,"sexo")}
${criarBadges(mini.cenarios,"cenario")}

</div>

</div>

</div>

</a>

</div>

`;

}

if(
container
){

container.innerHTML =
embaralhar(dados)
.slice(0,6)
.map(criarCard)
.join("");

}

</script>

<style>

.hero-home{

background:var(--kl-dark);
color:#fff;

padding:58px 0 0;

position:relative;
overflow:hidden;

}

.hero-conteudo{

position:relative;
z-index:2;

padding-bottom:44px;

}

.hero-home h1{

color:var(--kl-gold);

font-size:clamp(2.1rem,4vw,3.4rem);
font-weight:800;

margin-bottom:12px;

}

.hero-home p{

max-width:620px;

margin:0 auto 24px;

font-size:1.05rem;
color:rgba(255,255,255,.82);

}

.faixas-aviso{

width:100%;

display:flex;
flex-direction:column;
gap:12px;

padding:0 0 32px;

position:relative;
z-index:2;

pointer-events:none;

}

.faixa{

width:100%;

background:#ffc107;
color:#111;

border-top:4px solid #000;
border-bottom:4px solid #000;

box-shadow:0 7px 0 rgba(0,0,0,.55);

font-weight:900;
text-align:center;
line-height:1;

white-space:nowrap;
overflow:hidden;

animation:faixaFlutuar 3.8s ease-in-out infinite;

}

.faixa span{

display:block;

padding:12px 18px;

}

.faixa-principal{

font-size:1.12rem;

background:
repeating-linear-gradient(
-45deg,
#111 0 12px,
#111 12px,
#ffc107 12px 28px
);

}

.faixa-principal span{

background:#ffc107;

display:inline-block;

padding:12px 34px;

border-left:4px solid #000;
border-right:4px solid #000;

}

.faixa-secundaria{

font-size:.82rem;

animation-delay:.4s;

}

.faixa-secundaria span{

padding:10px 18px;

}

@keyframes faixaFlutuar{

0%,100%{
transform:translateY(0);
}

50%{
transform:translateY(-4px);
}

}

.destaques-topo h2{

font-size:1.8rem;
font-weight:800;

margin-bottom:6px;

}

.destaques-topo p{

color:#6c757d;

margin-bottom:24px;

}

.card-home{

overflow:hidden;

transition:.2s ease;

}

.card-home:hover{

transform:translateY(-4px);

box-shadow:0 10px 24px rgba(0,0,0,.16) !important;

}

.card-home img{

width:100%;
aspect-ratio:1.35/1;
object-fit:cover;

}

.card-home .card-body{

padding:.8rem;

}

.card-home .card-title{

font-size:1.05rem;
font-weight:700;

}

:global(.badge-home){

display:inline-flex;
align-items:center;

padding:.3em .48em;

border-radius:.375rem;

font-size:.68rem;
font-weight:600;

line-height:1;

}

:global(.badge-classe){

background:#212529 !important;
color:#fff !important;

}

:global(.badge-raca){

background:#ffc107 !important;
color:#000 !important;

}

:global(.badge-sexo){

background:#b23a48 !important;
color:#fff !important;

}

:global(.badge-cenario){

background:#fff !important;
color:#212529 !important;

border:1px solid #dee2e6;

}

@media(min-width:993px){

.hero-home{

padding:58px 0;

}

.hero-conteudo{

padding-bottom:0;

}

.faixas-aviso{

position:absolute;
right:clamp(18px,4vw,70px);
top:50%;
transform:translateY(-50%);

width:280px;

padding:0;

gap:12px;

}

.faixa{

border:4px solid #000;
border-radius:0;

box-shadow:6px 7px 0 rgba(0,0,0,.55);

}

.faixa-principal{

font-size:1rem;

}

.faixa-principal span{

display:block;

border-left:0;
border-right:0;

padding:12px 14px;

}

.faixa-secundaria{

font-size:.64rem;

}

.faixa-secundaria span{

padding:10px 12px;

}

}

@media(max-width:1200px) and (min-width:993px){

.faixas-aviso{

right:14px;
width:230px;

}

.faixa-principal{

font-size:.88rem;

}

.faixa-secundaria{

font-size:.56rem;

}

}

@media(max-width:768px){

.hero-home{

padding-top:58px;

}

.hero-conteudo{

padding-bottom:38px;

}

.hero-home p{

font-size:1rem;

}

.faixas-aviso{

gap:10px;

padding-bottom:28px;

}

.faixa-principal{

font-size:.98rem;

}

.faixa-principal span{

padding:11px 26px;

}

.faixa-secundaria{

font-size:.68rem;

}

.faixa-secundaria span{

padding:9px 14px;

}

.card-home img{

aspect-ratio:1/1;

}

.card-home .card-body{

padding:.65rem;

}

.card-home .card-title{

font-size:.9rem;

}

:global(.badge-home){

font-size:.62rem;
padding:.28em .42em;

}

}

@media(max-width:430px){

.faixa-principal{

font-size:.9rem;

}

.faixa-secundaria{

font-size:.6rem;

}

}

</style>

</Layout>
