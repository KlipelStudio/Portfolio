---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import MiniCard from '../../components/MiniCard.astro';

const minis=await getCollection('minis');

const classes=[
...new Set(
minis.flatMap(
m=>m.data.classes||[]
)
)
].sort();
---

<Layout titulo="Classes">

<section class="container py-5">

<div class="row">

<div class="col-3">

<h3>Classes</h3>

<div id="filtros">

{
classes.map(c=>(
<div>

<label>

<input
type="checkbox"
value={c}
class="filtro"
/>

{c}

</label>

</div>
))
}

</div>

</div>

<div class="col-9">

<div
class="row g-4"
id="grid"
>

{
minis.map(m=>(

<div
class="col-6 mini"
data-classes={JSON.stringify(m.data.classes||[])}
>

<MiniCard mini={m}/>

</div>

))
}

</div>

</div>

</div>

</section>

<script is:inline>

const filtros=document.querySelectorAll(".filtro");

filtros.forEach(f=>{

f.addEventListener("change",()=>{

const ativos=[
...document.querySelectorAll(".filtro:checked")
].map(x=>x.value);

document.querySelectorAll(".mini")
.forEach(el=>{

const classes=
JSON.parse(
el.dataset.classes
);

if(
ativos.length===0
||
ativos.some(
a=>classes.includes(a)
)
){

el.style.display="";

}else{

el.style.display="none";

}

});

});

});

</script>

</Layout>
