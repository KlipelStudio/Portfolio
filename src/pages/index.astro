---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const base = import.meta.env.BASE_URL;

const url = (p) =>
`${base}${p}`.replace(/\/{2,}/g,'/');

const minis = await getCollection('minis');

const miniaturas = minis
.filter(
  m => m.data.destaque === true
)
.map(m=>({
  slug:m.slug,
  href:url(`/minis/${m.slug}/`),
  titulo:m.data.titulo,
  imagem:m.data.imagem,
  classes:m.data.classes || [],
  racas:m.data.racas || [],
  sexo:m.data.sexo || [],
  cenarios:m.data.cenarios || []
}));
---

<Layout titulo="Klipel Studio — Miniaturas para Aventureiros">

<section class="hero-home">

<div class="container text-center hero-conteudo">

<h1>
Miniaturas para suas aventuras
</h1>

<p>
Heróis, vilões, monstros e cenários para dar vida às suas mesas de RPG.
</p>

<a
href={url('/galeria')}
class="btn btn-warning btn-lg px-5"
>
VER PORTFÓLIO
</a>

</div>

<div class="baloes-cartoon" aria-label="Avisos do site">

<div class="balao balao-grande">
<span>
Atualizações<br />semanais 🔥
</span>
</div>

<div class="balao balao-pequeno">
<span>
Não encontrou o que procura?<br />
Entre em contato com a gente!
</span>
</div>

</div>

</section>

<section class="container py-4">

<div class="destaques-topo text-center">

<h2>
Destaques
</h2>

<p>
Uma seleção do nosso catálogo.
</p>

</div>

{
miniaturas.length===0
? (
<p class="text-center text-muted">
Nenhuma miniatura cadastrada ainda.
</p>
)
: (
<div
id="vitrine-aleatoria"
class="row g-3"
></div>
)
}

<div class="text-center mt-4">

<a
href={url('/galeria')}
class="btn btn-dark"
>
Ver todas as miniaturas
</a>

</div>

</section>

<script
type="application/json"
id="miniaturas-data"
set:html={JSON.stringify(miniaturas)}
/>

<script is:inline>

const base =
document
.querySelector(
"base"
)
?.href || "/";

const dados =
JSON.parse(
document
.querySelector(
"#miniaturas-data"
)
.textContent
);

const container =
document.querySelector(
"#vitrine-aleatoria"
);

function asset(p){

if(
/^https?:\/\//.test(p)
){

return p;

}

return `${base}${p}`.replace(
/\/{2,}/g,
"/"
);

}

function embaralhar(lista){

return [...lista].sort(
()=>Math.random()-.5
);

}

function criarBadges(lista,tipo){

return lista.map(item=>`

<span class="badge badge-home badge-${tipo}">
${item}
</span>

`).join("");

}

function criarCard(mini){

const href =
mini.href;

const img =
asset(mini.imagem);

return `

<div class="col-6 col-lg-4">

<a href="${href}" class="text-decoration-none text-reset">

<div class="card card-home h-100 shadow-sm border-0">

<img
src="${img}"
class="card-img-top"
alt="${mini.titulo}"
/>

<div class="card-body">

<h3 class="card-title mb-2">
${mini.titulo}
</h3>

<div class="d-flex flex-wrap gap-1">

${criarBadges(mini.classes,"classe")}
${criarBadges(mini.racas,"raca")}
${criarBadges(mini.sexo,"sexo")}
${criarBadges(mini.cenarios,"cenario")}

</div>

</div>

</div>

</a>

</div>

`;

}

if(
container
){

container.innerHTML =
embaralhar(dados)
.slice(0,6)
.map(criarCard)
.join("");

}

</script>

<style>

.hero-home{

background:var(--kl-dark);
color:#fff;

padding:58px 0;

position:relative;
overflow:hidden;

}

.hero-conteudo{

position:relative;
z-index:2;

}

.hero-home h1{

color:var(--kl-gold);

font-size:clamp(2.1rem,4vw,3.4rem);
font-weight:800;

margin-bottom:12px;

}

.hero-home p{

max-width:620px;

margin:0 auto 24px;

font-size:1.05rem;
color:rgba(255,255,255,.82);

}

.baloes-cartoon{

position:absolute;
right:clamp(18px,4vw,70px);
top:50%;
transform:translateY(-50%);

display:flex;
flex-direction:column;
align-items:flex-end;
gap:18px;

z-index:1;
pointer-events:none;

}

.balao{

position:relative;

background:#ffc107;
color:#111;

border:4px solid #000;

box-shadow:6px 7px 0 rgba(0,0,0,.55);

font-weight:900;
line-height:1.05;
text-align:center;

filter:drop-shadow(0 8px 12px rgba(0,0,0,.22));

}

.balao::before,
.balao::after{

content:"";
position:absolute;
background:#000;

clip-path:polygon(0 0,100% 50%,0 100%);

}

.balao-grande{

width:255px;
min-height:125px;

padding:30px 22px;

font-size:1.55rem;

border-radius:45% 55% 48% 52% / 58% 45% 55% 42%;

transform:rotate(-8deg);

animation:balaoFlutuarGrande 3.6s ease-in-out infinite;

}

.balao-grande::before{

width:32px;
height:24px;

right:-34px;
top:22px;

transform:rotate(-12deg);

}

.balao-grande::after{

width:26px;
height:20px;

left:-30px;
bottom:18px;

transform:rotate(178deg);

}

.balao-pequeno{

width:245px;

padding:18px 18px;

font-size:.92rem;

border-radius:34px;

animation:balaoFlutuarPequeno 4.2s ease-in-out infinite;

}

.balao-pequeno::before{

width:22px;
height:18px;

right:-24px;
bottom:18px;

}

.balao span{

position:relative;
z-index:2;

}

@keyframes balaoFlutuarGrande{

0%,100%{
transform:rotate(-8deg) translateY(0);
}

50%{
transform:rotate(-6deg) translateY(-8px);
}

}

@keyframes balaoFlutuarPequeno{

0%,100%{
transform:translateY(0);
}

50%{
transform:translateY(7px);
}

}

.destaques-topo h2{

font-size:1.8rem;
font-weight:800;

margin-bottom:6px;

}

.destaques-topo p{

color:#6c757d;

margin-bottom:24px;

}

.card-home{

overflow:hidden;

transition:.2s ease;

}

.card-home:hover{

transform:translateY(-4px);

box-shadow:0 10px 24px rgba(0,0,0,.16) !important;

}

.card-home img{

width:100%;
aspect-ratio:1.35/1;
object-fit:cover;

}

.card-home .card-body{

padding:.8rem;

}

.card-home .card-title{

font-size:1.05rem;
font-weight:700;

}

:global(.badge-home){

display:inline-flex;
align-items:center;

padding:.3em .48em;

border-radius:.375rem;

font-size:.68rem;
font-weight:600;

line-height:1;

}

:global(.badge-classe){

background:#212529 !important;
color:#fff !important;

}

:global(.badge-raca){

background:#ffc107 !important;
color:#000 !important;

}

:global(.badge-sexo){

background:#b23a48 !important;
color:#fff !important;

}

:global(.badge-cenario){

background:#fff !important;
color:#212529 !important;

border:1px solid #dee2e6;

}

@media(max-width:1200px){

.baloes-cartoon{

opacity:.95;
right:18px;

}

.balao-grande{

width:220px;
font-size:1.32rem;

}

.balao-pequeno{

width:215px;
font-size:.82rem;

}

}

@media(max-width:992px){

.hero-home{

padding:58px 0 46px;

}

.baloes-cartoon{

position:relative;
right:auto;
top:auto;
transform:none;

width:100%;
max-width:520px;

margin:30px auto 0;
padding:0 18px;

align-items:center;

z-index:2;

}

.balao-grande{

width:min(100%,310px);
min-height:auto;

padding:22px 18px;

font-size:1.28rem;

}

.balao-pequeno{

width:min(100%,320px);

padding:15px 14px;

font-size:.82rem;

}

}

@media(max-width:768px){

.hero-home{

padding:58px 0 42px;

}

.hero-home p{

font-size:1rem;

}

.baloes-cartoon{

margin-top:34px;
gap:14px;

}

.balao-grande{

font-size:1.18rem;
transform:rotate(-5deg);

}

.balao-pequeno{

font-size:.78rem;

}

.card-home img{

aspect-ratio:1/1;

}

.card-home .card-body{

padding:.65rem;

}

.card-home .card-title{

font-size:.9rem;

}

:global(.badge-home){

font-size:.62rem;
padding:.28em .42em;

}

@keyframes balaoFlutuarGrande{

0%,100%{
transform:rotate(-5deg) translateY(0);
}

50%{
transform:rotate(-3deg) translateY(-6px);
}

}

}

</style>

</Layout>
