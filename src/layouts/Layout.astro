---
const { titulo = 'Klipel Studio', descricao = 'Miniaturas artesanais para aventureiros de RPG.' } = Astro.props;
const base = import.meta.env.BASE_URL;
const url = (p) => `${base}${p}`.replace(/\/{2,}/g, '/');
const path = Astro.url.pathname;
---

<!doctype html>
<html lang="pt-BR">
<head>
<meta charset="utf-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1"/>
<meta name="robots" content="noindex, nofollow"/>
<meta name="googlebot" content="noindex, nofollow"/>
<title>{titulo}</title>
<meta name="description" content={descricao}/>

<link
href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
rel="stylesheet"
/>

<style>
:root{
--kl-dark:#1a1410;
--kl-gold:#c9a45c;
}

body{
font-family:system-ui,sans-serif;
}

.hero{
background:linear-gradient(rgba(26,20,16,.78), rgba(26,20,16,.92));
}

.text-gold{
color:var(--kl-gold)!important;
}

.bg-forge{
background:var(--kl-dark);
}

.card-mini img{
aspect-ratio:4/3;
object-fit:cover;
}
</style>
</head>

<body class="d-flex flex-column min-vh-100">

<nav class="navbar navbar-dark bg-forge border-bottom">
<div class="container">

<a
class="navbar-brand fw-bold text-gold"
href={url('/')}
>
Klipel Studio
</a>

<div class="ms-auto">
<a
class:list={["nav-link text-light",{active:path==="/galeria/"}]}
href={url('/galeria')}
>
Galeria
</a>
</div>

</div>
</nav>

<main class="flex-grow-1">
<slot/>
</main>

</body>
</html>
