---
const { titulo = 'Klipel Studio', descricao = 'Miniaturas artesanais para aventureiros de RPG.' } = Astro.props;
const base = import.meta.env.BASE_URL;
const url = (p) => `${base}${p}`.replace(/\/{2,}/g, '/');
const nav = [
  { href: url('/'), txt: 'Início' },
  { href: url('/galeria'), txt: 'Galeria' },
  { href: url('/sobre'), txt: 'Sobre' },
  { href: url('/contato'), txt: 'Contato' },
];
const path = Astro.url.pathname;
---
<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{titulo}</title>
    <meta name="description" content={descricao} />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
      crossorigin="anonymous"
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@500;700&family=Inter:wght@400;600&display=swap" rel="stylesheet" />
    <style>
      :root { --kl-dark: #1a1410; --kl-gold: #c9a45c; }
      body { font-family: 'Inter', system-ui, sans-serif; }
      h1, h2, h3, .brand-font { font-family: 'Cinzel', serif; }
      .bg-forge { background: var(--kl-dark); }
      .text-gold { color: var(--kl-gold) !important; }
      .border-gold { border-color: var(--kl-gold) !important; }
      .card-mini img { aspect-ratio: 4/3; object-fit: cover; }
      .hero { background: linear-gradient(rgba(26,20,16,.78), rgba(26,20,16,.92)); }
      a.nav-link.active { color: var(--kl-gold) !important; }
    </style>
  </head>
  <body class="d-flex flex-column min-vh-100">
    <nav class="navbar navbar-expand-lg navbar-dark bg-forge border-bottom border-gold">
      <div class="container">
        <a class="navbar-brand brand-font text-gold fw-bold" href={url('/')}>Klipel Studio</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#nav" aria-controls="nav" aria-expanded="false" aria-label="Alternar navegação">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="nav">
          <ul class="navbar-nav ms-auto">
            {nav.map((n) => (
              <li class="nav-item">
                <a class:list={["nav-link", { active: path === n.href }]} href={n.href}>{n.txt}</a>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </nav>

    <main class="flex-grow-1">
      <slot />
    </main>

    <footer class="bg-forge text-light py-4 mt-5 border-top border-gold">
      <div class="container d-flex flex-column flex-md-row justify-content-between align-items-center gap-2">
        <span class="brand-font text-gold">Klipel Studio</span>
        <small class="text-secondary">© {new Date().getFullYear()} — Miniaturas artesanais para RPG. Feito com paixão por aventuras.</small>
      </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
  </body>
</html>
